<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Category icon with dot -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <ImageView
                android:id="@+id/iv_category_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_gray"
                android:padding="10dp"
                android:src="@drawable/ic_category_other" />

            <View
                android:id="@+id/v_category_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_dot"
                android:backgroundTint="@color/colorPrimary" />
        </FrameLayout>

        <!-- Title + Category + Date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_transaction_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Makan siang"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_transaction_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Makanan"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_chip_category"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/tv_transaction_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01 Jan 2025"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:id="@+id/tv_transaction_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- Rp 50.000"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/colorExpense" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
