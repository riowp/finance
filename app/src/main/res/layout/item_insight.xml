<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_insight"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_insight_emoji"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="💡"
                android:textSize="24sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_insight_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Insight"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_insight_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pesan insight"
            android:textSize="13sp"
            android:textColor="@color/colorOnSurface"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp" />

        <TextView
            android:id="@+id/tv_insight_suggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_suggestion"
            android:padding="10dp"
            android:lineSpacingExtra="2dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
